# Garmin API Configuration
# IMPORTANT: Do not commit real credentials or API keys.
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Garmin credential encryption (Base64 or 32-byte key)
GARMIN_CRED_ENCRYPTION_KEY=

# LLM Configuration
# Provider: "deepseek" or "gemini"
LLM_PROVIDER=deepseek

# DeepSeek API (default provider)
DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_MODEL_NAME=deepseek-reasoner
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini API (alternative provider)
# GEMINI_API_KEY=your_gemini_api_key

# Garmin Region Configuration
# True = connect.garmin.cn (China), False = connect.garmin.com (International)
GARMIN_IS_CN=false

# Proxy Configuration (optional, for accessing Google API)
# PROXY_URL=http://127.0.0.1:7890

# Database Configuration (MySQL)
# Example (本地开发):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/garmin_coach_dev?charset=utf8mb4
# Example (Docker部署):
# DATABASE_URL=mysql+pymysql://user:password@host:3306/garmin_coach?charset=utf8mb4
DATABASE_URL=

# Runtime behavior
# False = use real Garmin API, True = local mock data mode
USE_MOCK_MODE=false

# Daily analysis cache TTL in hours. Within this window, backend returns DB cached result.
ANALYSIS_CACHE_HOURS=24

# Polling job
ENABLE_GARMIN_POLLING=false
GARMIN_POLL_INTERVAL_MINUTES=30
INITIAL_BIND_BACKFILL_DAYS=30



